# ---- Base de datos (Postgres). En Vercel: Storage > Postgres (Neon) ----
# Prisma espera estas dos variables de entorno. En local puedes usar la misma URL de Postgres para ambas.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# ---- NextAuth ----
# Genera el secret con:  openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo"
# En local: http://localhost:3000  | En produccion: https://proyectos.cofersa.cr
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (Google Cloud Console > Credenciales) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Control de acceso por dominio corporativo (separados por coma) ----
ALLOWED_DOMAINS="mayoreo.biz,febeca.com,mundipartes.com,cofersa.cr,sillaca.biz,beval.biz"

# ---- Roles por correo (separados por coma). El resto entra como Visualizador ----
ADMIN_EMAILS="tu.correo@cofersa.cr"
EDITOR_EMAILS=""
